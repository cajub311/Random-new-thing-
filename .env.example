# CloudClaw - Free AI Provider Keys
# Copy this file to .env and fill in your keys.
# You only need ONE key to get started — all providers have free tiers!

# Groq (fastest, Llama 3 & Mixtral) — free at https://console.groq.com
GROQ_API_KEY=

# Google Gemini (most capable free tier) — free at https://aistudio.google.com
GEMINI_API_KEY=

# Cohere (Command R+) — free at https://dashboard.cohere.com
COHERE_API_KEY=

# Together AI (many open-source models) — free at https://api.together.xyz
TOGETHER_API_KEY=

# Hugging Face (100+ open models) — free at https://huggingface.co/settings/tokens
HF_API_KEY=

PORT=3000
