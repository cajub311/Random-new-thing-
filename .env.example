# OpenClaw — all keys optional.
#
# Default behavior (no env vars set):
#   1. If Ollama is running on http://localhost:11434, use it.
#   2. Else if LM Studio is running on http://localhost:1234, use it.
#   3. Else use the free keyless Pollinations cloud provider.
#
# Only set the variables below if you want to override defaults or unlock
# additional cloud providers.

# ── Local LLM runtimes ─────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
LMSTUDIO_URL=http://localhost:1234
LMSTUDIO_MODEL=local-model
LLAMACPP_URL=http://localhost:8080

# ── Free cloud providers (keys are optional) ───────────────────────────
GROQ_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=
TOGETHER_API_KEY=
# Hugging Face user token (hf_…) — used with Inference Providers router in OpenClaw.
# Token needs permission to call Inference Providers (see HF account → Access Tokens).
HF_API_KEY=

# xAI Grok + Anthropic Claude (optional; or paste keys in the OpenClaw UI)
XAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional messaging adapters ────────────────────────────────────────
# Set TELEGRAM_BOT_TOKEN to run the Telegram bot (long-polling, no webhook
# config needed). Create a bot via @BotFather on Telegram.
TELEGRAM_BOT_TOKEN=

# ── Operational ────────────────────────────────────────────────────────
PORT=3000
LOG_LEVEL=info        # debug | info | warn | error
LOG_FORMAT=pretty     # pretty | json
WORKSPACE_DIR=        # default: ./workspace (serverless fallback to /tmp)
