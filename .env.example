# CloudClaw — Free AI Provider Keys
#
# ⚡ NO KEYS REQUIRED TO GET STARTED! ⚡
# CloudClaw ships with the keyless Pollinations provider, so it works out of
# the box. Everything below is OPTIONAL — add a key only if you want to use
# that specific provider as a fallback or preference.

# Groq (fastest Llama 3 inference) — https://console.groq.com
GROQ_API_KEY=

# Google Gemini (most capable free tier) — https://aistudio.google.com
GEMINI_API_KEY=

# Cohere (Command R+) — https://dashboard.cohere.com
COHERE_API_KEY=

# Together AI (many open-source models) — https://api.together.xyz
TOGETHER_API_KEY=

# Hugging Face (100+ open models) — https://huggingface.co/settings/tokens
HF_API_KEY=

# Port for local dev
PORT=3000
